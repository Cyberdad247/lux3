{
  "version": "1.0",
  "codename": "SOVEREIGN_NEXUS",
  "site": "lux3",
  "role": "Nexus — Agentic Ops Dashboard",
  "created": "2026-05-01",
  "architect": "SIR_BORIS v3.0",
  "inherits_from": "../lux11/.hive/SITE_2_DNA.json",

  "colors": {
    "obsidian":        "#000000",
    "gold":            "#D4AF37",
    "platinum":        "#E8E4D9",
    "agent_active":    "#D4AF37",
    "agent_streaming": "rgba(56,189,248,0.7)",
    "agent_pass":      "rgba(52,211,153,0.7)",
    "agent_idle":      "rgba(255,255,255,0.2)",
    "agent_dark":      "rgba(255,255,255,0.08)"
  },

  "typography": {
    "terminal_font":    "'Space Mono', 'JetBrains Mono', 'Fira Code', ui-monospace, monospace",
    "tracking_command": "0.05em",
    "tracking_label":   "0.45em",
    "weight":           "400",
    "size_command":     "11px",
    "size_label":       "9px",
    "size_metric":      "clamp(1.25rem, 2.5vw+0.25rem, 2rem)"
  },

  "easing": {
    "fluid":    [0.22, 1, 0.36, 1],
    "sovereign": [0.77, 0, 0.175, 1]
  },

  "layout": {
    "header_height_px":    56,
    "grid_cols_desktop":   5,
    "neural_feed_span":    3,
    "telemetry_span":      2,
    "divider_opacity":     0.05,
    "panel_padding_px":    20,
    "row_height_px":       40
  },

  "telemetry": {
    "feed_interval_ms":        4000,
    "terminal_line_delay_ms":  120,
    "metric_animate_duration": 2.2,
    "max_feed_events":         20,
    "idle_prompt_interval_ms": 5200
  },

  "performance": {
    "lcp_target_ms":     1200,
    "bundle_target_kb":  160,
    "doherty_threshold": 400,
    "ssr_strategy":      "all panels server-compatible; client islands for live feed + terminal"
  },

  "security": {
    "mcp_tokens":        "server-side only — never in JSX or client component props",
    "terminal_display":  "React text nodes only — no dangerouslySetInnerHTML",
    "xss_protection":    "all rendered strings sourced from hardcoded constants",
    "client_isolation":  "no API keys, credentials, or tokens in any client component"
  }
}
